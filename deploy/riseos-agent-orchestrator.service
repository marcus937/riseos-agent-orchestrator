[Unit]
Description=RiseOS Agent Orchestrator FastAPI service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=riseos
Group=riseos
WorkingDirectory=/opt/riseos-agent-orchestrator
EnvironmentFile=/etc/riseos-agent-orchestrator.env
ExecStart=/opt/riseos-agent-orchestrator/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/riseos-agent-orchestrator

[Install]
WantedBy=multi-user.target
